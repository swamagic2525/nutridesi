# Which LLM to use for parsing: "groq" (free, default), "gemini", or "claude"
LLM_PROVIDER=groq

# Groq (from console.groq.com/keys — free, no card, generous limits)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# Gemini (from aistudio.google.com/apikey — free but low daily cap)
GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash

# Anthropic (only if LLM_PROVIDER=claude; from console.anthropic.com — paid)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Twilio (from console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here

# Supabase (from your project settings > API)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Server
PORT=3000

# Phone that receives healthcheck watchdog alerts
ALERT_PHONE=+91XXXXXXXXXX
TWILIO_WHATSAPP_FROM=+14155238886
